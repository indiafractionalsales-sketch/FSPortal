rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Restrict profile documents to their authenticated owner using userId as document ID
    match /OBO_Profile/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /SP_Profile/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /TPSP_Profile/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (!resource.data.keys().has('role') || resource.data.role == request.resource.data.role)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'billing']);
    }

    match /users/{userId}/Invoices/{invoiceId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server-side admin SDK writes Invoices
    }

    match /Pricing_Configs/{region} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Unified Posts Collection (for SP and OBO posts)
    match /Posts/{postId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      
      match /Comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorUid;
        allow delete, update: if request.auth != null && request.auth.uid == resource.data.authorUid;
      }

      match /Offers/{offerId} {
        // Post owner can read all offers; SP can read their own
        allow read: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/Posts/$(postId)).data.ownerUid
              || request.auth.uid == resource.data.offerorUid);
        
        // SPs can create offers on posts they don't own
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.offerorUid
          && request.auth.uid != get(/databases/$(database)/documents/Posts/$(postId)).data.ownerUid;
        
        // Post owner can accept/decline; offeror can withdraw
        allow update: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/Posts/$(postId)).data.ownerUid
              || (request.auth.uid == resource.data.offerorUid 
                  && request.resource.data.status == "withdrawn"));
        
        allow delete: if false;
      }
    }

    // AI Lead Capture - Root collection for macro-analytics
    match /Leads/{leadId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.ownerUid
                      || request.auth.uid == resource.data.capturedByUid);
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerUid;
    }

    // Post-Deal Rating & Review Engine
    match /Reviews/{reviewId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.reviewerUid;
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.reviewerUid
                      || request.auth.uid == resource.data.targetUid);
      // Reviews cannot be updated or deleted once submitted
    }

    // Attendance & Location Tracking
    match /Attendance/{attendanceId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.partnerId
                      || request.auth.uid == resource.data.clientId);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.partnerId;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.partnerId
                        || request.auth.uid == resource.data.clientId);
      allow delete: if false;
    }
  }
}
